                    dataKey="minutes"
                    fill={isStandard ? "#ef4444" : "#38bdf8"}
                    radius={[6, 6, 0, 0]}
                    barSize={42}
                    animationDuration={900}
                  />
                </BarChart>
              </ResponsiveContainer>
            </div>

